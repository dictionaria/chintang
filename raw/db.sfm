\morph yuŋ
\ps vt
\mtyp stem
\val A-ERG G-LOC T-NOM V-a(A).o(T)
\de put; put.away; put.down; keep; let.be.there
\gn राख्नु
\lg C
\ex Ba heŋga yoʔni yuŋsandakhanum.
\exe Put this bowl over there.
\exn यो डाली परतिर राख ।
\exsrc CLDLCh3R05S01.043b
\ex Theke dori akattoŋse? Yuŋsuthowa!
\exe Why did you bring up the rope? Put it back!
\exn किन डोरी ल्याएको ? राख्न जाऊ !
\exsrc CLLDCh1R05S01 490
\ex Maʔmiŋa kitap tebulbe yuŋsose.
\exe The man put the book on the table. 
\exsrc VAL068
\ex huŋgo sambali yuŋmayaŋ bhãda
\exe the pot where the soybeans have been put
\exsrc VAL163
\ex Maʔmiŋa gadibe ghãsa yuŋsose.
\exe The man has loaded hay onto the truck.
\exsrc VAL074
\qst

