\ps vi
\val S-NOM V-s(S)
\de throw.oneself; jump
\gn हामफाल्नु
\lg C
\ex Huŋgo onadinace pho inarabe.
\exe They say it jumped into the well.
\exsrc VAL157
\com lexicalised reflexive of os- ‘throw’
\qst

\lex os
\ct oma
\morph o
\ps vt
\val A-ERG G-LOC T-NOM(1) V-a(A).o(T)
\de throw
\gn फाल्नु; फ्याँक्नु
\lg C
\ex Limno hola ni, aosandukum naŋ!
\exe It probably tastes good, but you just throw it around!
\exn मीठो होला नि, तर तिमीहरूले फ्याँकीहाल्छौ त !
\exsrc CLLDCh1R06S03.0023
\ex Chaŋa jaskelibe luŋtak osose.
\exe The child has thrown a stone into the window.
\exsrc VAL064
\ex Kancha, mo inisa osa!
\exe Kancha, throw (something) on your younger brother down there!
\exsrc VAL151
\qst

